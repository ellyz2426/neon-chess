<panel width="280" height="260" backgroundColor="#000a14" borderRadius="8" borderColor="#00e5ff" borderWidth="1" flexDirection="column" alignItems="center" padding="12">
  <text fontSize="18" fontWeight="bold" color="#00e5ff" marginBottom="10">AI DIFFICULTY</text>
  <text name="btn-easy" fontSize="13" color="#4caf50" backgroundColor="#0a2010" padding="6" borderRadius="4" width="180" textAlign="center" marginBottom="4" cursor="pointer">EASY (Depth 1)</text>
  <text name="btn-medium" fontSize="13" color="#ffa726" backgroundColor="#1a1200" padding="6" borderRadius="4" width="180" textAlign="center" marginBottom="4" cursor="pointer">MEDIUM (Depth 2)</text>
  <text name="btn-hard" fontSize="13" color="#f44336" backgroundColor="#1a0a08" padding="6" borderRadius="4" width="180" textAlign="center" marginBottom="4" cursor="pointer">HARD (Depth 3)</text>
  <text name="btn-expert" fontSize="13" color="#e040fb" backgroundColor="#1a0820" padding="6" borderRadius="4" width="180" textAlign="center" marginBottom="4" cursor="pointer">EXPERT (Depth 4)</text>
  <text name="btn-diff-back" fontSize="12" color="#888888" backgroundColor="#111111" padding="5" borderRadius="4" width="180" textAlign="center" marginTop="4" cursor="pointer">BACK</text>
</panel>
